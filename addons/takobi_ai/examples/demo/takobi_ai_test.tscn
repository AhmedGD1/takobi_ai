[node name="DeathSequence" type="Node" parent="Enemy/EnemyBT/ReactiveSelector" unique_id=1854758623]
editor_description = "Sequence excute each node in order.

first: HealthBelowZero Condition
second: CallDieMethod action
etc.

if one of them returns failure, sequence returns failure (opposite from selector)"
