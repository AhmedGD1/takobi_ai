[node name="ReactiveSelector" type="Node" parent="Enemy/EnemyBT" unique_id=730071002]
editor_description = "Re-checks DeathSequence every tick, even while ChaseSequence is running. If the enemy dies mid-chase, it interrupts ChaseTarget immediately instead of waiting for it to finish."
