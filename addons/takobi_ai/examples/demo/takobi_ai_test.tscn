[node name="CallDieMethod" type="Node" parent="Enemy/EnemyBT/ReactiveSelector/DeathSequence" unique_id=1394302224 node_paths=PackedStringArray("Source")]
editor_description = "Call Method Action is designed to be an alternatives of simple custom actions.

instead of making a whole action to make enemy die, just make a method in a component or agent script & call it from here.

note: Call method supports, failure return when method is a bool type & returns falss. That means CallMethod Can work like a condition as well."
script = ExtResource("6_ui4nh")
Source = NodePath("../../../..")
Method = &"Die"
metadata/_custom_type_script = "uid://dv2xc3tc8xabc"

